{
  "enabled": true,
  "name": "Auto Sync KiroWorkspace",
  "description": "Automatically syncs to Google Drive when any steering or rule file is saved in AISpace",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "**/*.md",
      "**/*.json",
      "**/*.txt"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "powershell -WindowStyle Hidden -Command \"& 'C:\\Godot\\3d-practice\\SYNC_TO_GEMINI_SILENT.bat'\"",
    "timeout": 120
  }
}