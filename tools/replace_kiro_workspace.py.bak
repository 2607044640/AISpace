"""
Scan C:\\Godot\\AISpace and C:\\Godot\\3d-practice for the literal string
"KiroWorkingSpace" and replace it with "AISpace".

Default mode = DRY RUN (no files modified). Use --apply to actually write.

Usage:
    python replace_kiro_workspace.py              # dry run, prints all hits
    python replace_kiro_workspace.py --apply      # perform replacement
    python replace_kiro_workspace.py --apply --backup  # also write .bak files
"""

from __future__ import annotations

import argparse
import sys
from pathlib import Path
from datetime import datetime

OLD = "KiroWorkingSpace"
NEW = "AISpace"

ROOTS = [
    Path(r"C:\Godot\AISpace"),
    Path(r"C:\Godot\3d-practice"),
]

# Directories we never touch (case-insensitive name match on any path segment)
SKIP_DIRS = {
    ".git",
    ".godot",
    ".vs",
    ".idea",
    ".vscode",
    "bin",
    "obj",
    "node_modules",
    "__pycache__",
    ".import",
    "build",
    "dist",
}

# File extensions considered safe text. Anything else is probed.
TEXT_EXTS = {
    ".md", ".txt", ".cs", ".gd", ".tscn", ".tres", ".cfg", ".json",
    ".xml", ".yml", ".yaml", ".ini", ".toml", ".py", ".ps1", ".bat",
    ".cmd", ".sh", ".csproj", ".sln", ".editorconfig", ".gitignore",
    ".gdshader", ".shader", ".import", ".log", ".uid",
}

# Hard skip: binary-ish extensions
BINARY_EXTS = {
    ".png", ".jpg", ".jpeg", ".gif", ".bmp", ".webp", ".ico",
    ".ogg", ".wav", ".mp3", ".mp4", ".ttf", ".otf", ".woff", ".woff2",
    ".exe", ".dll", ".pdb", ".so", ".dylib", ".zip", ".7z", ".rar",
    ".pck", ".scn", ".ctex", ".stex", ".res",
    ".pdf", ".psd", ".blend", ".fbx", ".glb", ".gltf",
}


def should_skip_dir(p: Path) -> bool:
    return any(part.lower() in SKIP_DIRS for part in p.parts)


def is_probably_text(data: bytes) -> bool:
    if b"\x00" in data[:8192]:
        return False
    try:
        data.decode("utf-8")
        return True
    except UnicodeDecodeError:
        pass
    try:
        data.decode("utf-8-sig")
        return True
    except UnicodeDecodeError:
        return False


def iter_candidate_files(root: Path):
    for p in root.rglob("*"):
        if not p.is_file():
            continue
        if should_skip_dir(p.parent):
            continue
        ext = p.suffix.lower()
        if ext in BINARY_EXTS:
            continue
        yield p


def scan_file(path: Path):
    """Return (hits_count, encoding, line_previews[]) or None if skipped."""
    try:
        raw = path.read_bytes()
    except (OSError, PermissionError) as e:
        print(f"[WARN] Cannot read {path}: {e}", file=sys.stderr)
        return None

    ext = path.suffix.lower()
    if ext not in TEXT_EXTS and not is_probably_text(raw):
        return None

    # Detect encoding
    if raw.startswith(b"\xef\xbb\xbf"):
        encoding = "utf-8-sig"
    else:
        encoding = "utf-8"

    try:
        text = raw.decode(encoding)
    except UnicodeDecodeError:
        return None

    if OLD not in text:
        return (0, encoding, [])

    previews = []
    for i, line in enumerate(text.splitlines(), start=1):
        if OLD in line:
            previews.append((i, line.strip()[:200]))
    return (text.count(OLD), encoding, previews)


def apply_replacement(path: Path, encoding: str, backup: bool) -> int:
    raw = path.read_bytes()
    # Re-decode with same encoding to preserve BOM semantics
    text = raw.decode(encoding)
    new_text = text.replace(OLD, NEW)
    if new_text == text:
        return 0
    if backup:
        bak = path.with_suffix(path.suffix + ".bak")
        bak.write_bytes(raw)
    # Write back preserving BOM if utf-8-sig
    path.write_bytes(new_text.encode(encoding))
    return text.count(OLD)


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument("--apply", action="store_true",
                        help="Actually perform replacement (default: dry run)")
    parser.add_argument("--backup", action="store_true",
                        help="Write .bak copies when applying")
    args = parser.parse_args()

    mode = "APPLY" if args.apply else "DRY-RUN"
    ts = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    log_lines = [f"# Replace '{OLD}' -> '{NEW}'  ({mode})  {ts}", ""]

    total_files = 0
    total_hits = 0
    modified_files = 0

    for root in ROOTS:
        if not root.exists():
            msg = f"[SKIP] Root not found: {root}"
            print(msg)
            log_lines.append(msg)
            continue
        header = f"\n=== Scanning {root} ==="
        print(header)
        log_lines.append(header)

        for path in iter_candidate_files(root):
            result = scan_file(path)
            if result is None:
                continue
            hits, encoding, previews = result
            if hits == 0:
                continue
            total_files += 1
            total_hits += hits
            entry = f"\n[{hits:>3} hit(s)] {path}  (enc={encoding})"
            print(entry)
            log_lines.append(entry)
            for ln, preview in previews:
                line_out = f"    L{ln}: {preview}"
                print(line_out)
                log_lines.append(line_out)

            if args.apply:
                changed = apply_replacement(path, encoding, args.backup)
                if changed:
                    modified_files += 1
                    msg = f"    -> MODIFIED ({changed} replacement(s))"
                    print(msg)
                    log_lines.append(msg)

    summary = (
        f"\n=== SUMMARY ({mode}) ===\n"
        f"Files with matches: {total_files}\n"
        f"Total occurrences : {total_hits}\n"
        f"Files modified    : {modified_files if args.apply else 0}\n"
    )
    print(summary)
    log_lines.append(summary)

    log_path = Path(__file__).with_name(
        f"replace_kiro_{'apply' if args.apply else 'dryrun'}_"
        f"{datetime.now().strftime('%Y%m%d_%H%M%S')}.log"
    )
    log_path.write_text("\n".join(log_lines), encoding="utf-8")
    print(f"Log written: {log_path}")

    if not args.apply and total_hits > 0:
        print("\n>>> Dry run only. Re-run with --apply to write changes.")
    return 0


if __name__ == "__main__":
    sys.exit(main())
